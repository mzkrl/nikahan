# Database (Neon/PostgreSQL)
POSTGRES_URL=postgresql://username:password@host/database?sslmode=require

# Admin password for wedding admin panel
ADMIN=your_admin_password_here

# Optional: For shortlink generation (TinyURL API)
SHORTLINK_API_KEY=

# Optional: Public site URL for generating invite links
PUBLIC_SITE_URL=https://your-site.vercel.app
